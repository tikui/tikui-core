{
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "target": "es2023",
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "test/**/*.ts",
    "vitest.config.ts",
    "tsdown.config.ts"
  ],
  "exclude": [
    "**/node_modules"
  ]
}
